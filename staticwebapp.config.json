{
  "routes": [
    { "route": "/", "serve": "/index.html" },
    { "route": "/temples", "serve": "/pages/temples/index.html" },
    { "route": "/hinduism", "serve": "/pages/hinduism/index.html" },
    { "route": "/festivals", "serve": "/pages/festivals/index.html" },
    { "route": "/vlogs", "serve": "/pages/vlogs/index.html" },
